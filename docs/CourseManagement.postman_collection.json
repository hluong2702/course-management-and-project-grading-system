{
  "info": {
    "name": "Course Management System API",
    "description": "RESTful API for Course & Grade Management - Java Web Service Project",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",      "value": "http://localhost:8080" },
    { "key": "accessToken",  "value": "" },
    { "key": "refreshToken", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "exec": [
            "var json = pm.response.json();",
            "if (json.data) {",
            "  pm.collectionVariables.set('accessToken',  json.data.accessToken);",
            "  pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
            "  pm.test('Login successful', () => pm.response.to.have.status(200));",
            "}"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"Admin@123\"\n}" }
          }
        },
        {
          "name": "Register (Student)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"newstudent\",\n  \"password\": \"Student@123\",\n  \"email\": \"newstudent@test.com\",\n  \"fullName\": \"New Student\"\n}" }
          }
        },
        {
          "name": "Refresh Token",
          "event": [{ "listen": "test", "script": { "exec": [
            "var json = pm.response.json();",
            "if (json.data) {",
            "  pm.collectionVariables.set('accessToken',  json.data.accessToken);",
            "  pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
            "}"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/refresh",
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/auth/logout"
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/auth/change-password",
            "body": { "mode": "raw", "raw": "{\n  \"currentPassword\": \"Admin@123\",\n  \"newPassword\": \"NewAdmin@456\"\n}" }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/forgot-password",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"student1@student.edu\",\n  \"newPassword\": \"Reset@123\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Admin - Users",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/users?page=0&size=10",
              "query": [
                { "key": "page",    "value": "0" },
                { "key": "size",    "value": "10" },
                { "key": "role",    "value": "STUDENT", "disabled": true },
                { "key": "keyword", "value": "nguyen",  "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get User By ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/admin/users/4"
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/v1/admin/users/4",
            "body": { "mode": "raw", "raw": "{\n  \"fullName\": \"Nguyen Van Hoang Updated\",\n  \"email\": \"hoang.updated@student.edu\"\n}" }
          }
        },
        {
          "name": "Toggle User Status",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/admin/users/4/toggle-status"
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/admin/users/6"
          }
        }
      ]
    },
    {
      "name": "Admin - Courses",
      "item": [
        {
          "name": "Create Course",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/v1/admin/courses",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Microservices with Spring Cloud\",\n  \"code\": \"MSC501\",\n  \"description\": \"Building scalable microservices\",\n  \"lecturerId\": 2\n}" }
          }
        },
        {
          "name": "Get All Courses",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/courses?page=0&size=10",
              "query": [
                { "key": "page",    "value": "0" },
                { "key": "size",    "value": "10" },
                { "key": "keyword", "value": "java", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Course By ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/admin/courses/1"
          }
        },
        {
          "name": "Update Course",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/v1/admin/courses/1",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Java Web Service (Updated)\",\n  \"code\": \"JWS301\",\n  \"description\": \"Updated description\",\n  \"lecturerId\": 2\n}" }
          }
        },
        {
          "name": "Delete Course (Soft)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/admin/courses/3"
          }
        }
      ]
    },
    {
      "name": "Courses (All Roles)",
      "item": [
        {
          "name": "List Courses",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/courses?page=0&size=10"
          }
        },
        {
          "name": "Search Courses",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/courses?keyword=java"
          }
        },
        {
          "name": "Get Course Detail",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/courses/1"
          }
        },
        {
          "name": "List Assignments in Course",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/courses/1/assignments"
          }
        },
        {
          "name": "Get Assignment Detail",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/courses/assignments/1"
          }
        },
        {
          "name": "List Lecture Materials",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/courses/1/materials"
          }
        },
        {
          "name": "List Enrollments in Course",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/courses/1/enrollments"
          }
        }
      ]
    },
    {
      "name": "Lecturer",
      "item": [
        {
          "name": "Create Assignment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/v1/lecturer/assignments",
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Session 03 - AOP & Logging\",\n  \"description\": \"Add AOP logging to your Spring Boot app\",\n  \"courseId\": 1,\n  \"deadline\": \"2025-12-31T23:59:59\"\n}" }
          }
        },
        {
          "name": "View Submissions for Assignment",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/lecturer/submissions/1?page=0&size=10"
          }
        },
        {
          "name": "Grade Submission",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/v1/lecturer/grades",
            "body": { "mode": "raw", "raw": "{\n  \"submissionId\": 2,\n  \"score\": 90,\n  \"feedback\": \"Well done! Clean code and good documentation.\"\n}" }
          }
        },
        {
          "name": "Upload Lecture Material",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/lecturer/materials/course/1?title=Session01-Slides",
            "body": {
              "mode": "formdata",
              "formdata": [{ "key": "file", "type": "file", "src": "/path/to/slides.pdf" }]
            }
          }
        }
      ]
    },
    {
      "name": "Student",
      "item": [
        {
          "name": "Enroll in Course",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/student/enrollments/course/2"
          }
        },
        {
          "name": "My Enrollments",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/student/enrollments?page=0&size=10"
          }
        },
        {
          "name": "Submit Assignment (GitHub)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/v1/student/submissions",
            "body": { "mode": "raw", "raw": "{\n  \"assignmentId\": 2,\n  \"githubUrl\": \"https://github.com/myusername/jwt-assignment\"\n}" }
          }
        },
        {
          "name": "Upload Report (PDF/Word)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/student/submissions/upload?assignmentId=2",
            "body": {
              "mode": "formdata",
              "formdata": [{ "key": "file", "type": "file", "src": "/path/to/report.pdf" }]
            }
          }
        },
        {
          "name": "My Submissions",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/student/submissions?page=0&size=10"
          }
        }
      ]
    }
  ]
}
